<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
  Ozone client configuration for Breeze integration tests.
  Points CLI to OM and SCM running in separate containers.
-->
<configuration>
  <property>
    <name>ozone.om.address</name>
    <value>om</value>
  </property>
  <property>
    <name>ozone.scm.names</name>
    <value>scm</value>
  </property>
  <property>
    <name>ozone.scm.client.address</name>
    <value>scm</value>
  </property>
  <property>
    <name>ozone.scm.block.client.address</name>
    <value>scm</value>
  </property>
  <property>
    <name>ozone.server.default.replication</name>
    <value>1</value>
  </property>
  <property>
    <name>ozone.server.default.replication.type</name>
    <value>RATIS</value>
  </property>
  <property>
    <name>ozone.replication</name>
    <value>ONE</value>
  </property>
  <property>
    <name>ozone.replication.type</name>
    <value>RATIS</value>
  </property>
</configuration>
